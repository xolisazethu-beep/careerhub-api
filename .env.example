# CareerHub — copy this file to `.env.local`, then run the app.
#
# The app origin. Server Components use it to fetch this app's own API routes
# (src/app/api/*). For local dev/prod this is the dev server origin; in a real
# deployment set it to your deployed origin. No external/Docker backend needed —
# jobs, applications, stats and the close action all run against the in-app API.
NEXT_PUBLIC_API_URL=http://localhost:3000
