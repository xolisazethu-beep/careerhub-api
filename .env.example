# CareerHubX — environment template.
# Copy to `.env.local` (`cp .env.example .env.local`) and fill in the values.
# Every data read/write goes to the REAL CareerHub backend — there is no mock
# layer — so the backend URL below must point at a running API.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Absolute base URL of the CareerHub backend (ASP.NET Core + Postgres, repo
# assignment-2-4). Versioned routes live under /api/v1 and use JWT auth.
#   • Local:  http://localhost:5080  (docker compose up -d + dotnet run)
#   • Deployed: your public API URL (Railway/Render/Azure), e.g.
#               https://careerhub-api.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080

# Auth.js v5 secret — signs the session cookie the middleware reads to gate
# role-restricted routes. Generate a fresh one per environment: `npx auth secret`
AUTH_SECRET=replace-me-run-npx-auth-secret

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# This app's own origin. Used by the few same-origin Next route handlers and to
# turn relative Open Graph URLs absolute. Align with `next dev` locally; set to
# your Vercel URL in production.
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry error monitoring (Assignment 3.4, Part 5 Step 4). Leave BLANK to disable
# Sentry entirely (src/instrumentation.ts becomes a no-op). To enable, create a
# project at sentry.io and paste its DSN. Set SENTRY_DSN as an env var on Vercel
# for production — never hardcode it.
#   • SENTRY_DSN            — server/edge runtimes (instrumentation.ts)
#   • NEXT_PUBLIC_SENTRY_DSN — browser runtime (exposed to the client bundle)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
